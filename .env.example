PORT=3000
CACHE_DIR=/cache
MEMORY_CACHE_MAX=2000
MEMORY_CACHE_TTL=3600
DISK_CACHE_TTL=86400
# Maximum total size of the disk cache in MB. When exceeded, the oldest
# entries (by mtime) are evicted. Set to 0 to disable the size cap.
CACHE_SIZE_MB=512
UPSTREAM_TIMEOUT=5000
UV_THREADPOOL_SIZE=16

# Number of cluster workers. Leave empty to default to the number of CPU cores.
WORKERS=

# Optional: enables the logo.dev provider (/l/:domain) when set to a valid publishable key.
# Get a key at https://www.logo.dev/
LOGODEV_TOKEN=

# Optional: set the default (first-tried) provider for /:domain requests.
# If omitted, the default fallback order is used (scraper first).
# Valid values: scraper, google, googlev2, duckduckgo, yandex,
#               faviconso, vemetric, favicondev, faviconkit, logodev,
#               selfhst, dashboardicons, lobehub
# Note: logodev requires LOGODEV_TOKEN to be set.
DEFAULT_PROVIDER=

# Optional: base URL of a sidecar besticon (https://github.com/mat/besticon)
# instance. When set, /s/:domain delegates icon discovery to besticon's
# /allicons.json?url=... endpoint and falls back to the built-in HTML scraper
# if besticon is unreachable or returns nothing. Inside the bundled
# docker-compose stack this is normally http://besticon:8080.
BESTICON_URL=

# Optional: in-memory cache for the enriched scraper icons list returned by
# /:domain/json. Each entry holds the merged besticon + static-hint + variant
# probe result for one domain. Avoids reprobing 8+ candidate URLs on every
# page load of the UI's size-button strip.
SCRAPER_ICONS_CACHE_TTL=3600
SCRAPER_ICONS_CACHE_MAX=500

# --- FaviconAPIs-style v1 API (GET /api/v1/favicon) ---
# Path to the SQLite file that stores hashed API keys and per-key monthly
# usage counters. Place it inside the same volume as CACHE_DIR so cluster
# workers and restarts share state.
API_KEYS_DB=/cache/api-keys.sqlite
# Directory where the normalized 256x256 PNGs returned by /api/v1/favicon
# are written. Served back over /cdn/favicons/{domain}.png.
API_CACHE_DIR=/cache/api
# How long a generated PNG counts as "cached" (seconds). Default = 7 days,
# matching FaviconAPIs.com. Also used as Cache-Control max-age on the CDN
# route.
API_CACHE_TTL=604800
# When set to "false" (or 0/no/off), /api/v1/favicon becomes a public
# endpoint: no Authorization header or ?key= is required, and per-key
# monthly quotas are not enforced. Useful for self-hosted deployments
# behind your own auth layer or for fully open APIs. Default = true.
# A provided key is silently ignored when this is false (it is not
# validated and its usage counter is not incremented).
API_REQUIRE_KEY=true
# Monthly call quotas per plan. 0 = unlimited. Defaults mirror
# FaviconAPIs.com's published Free/Pro/Enterprise tiers. Only applied
# when API_REQUIRE_KEY=true.
PLAN_FREE_LIMIT=25
PLAN_PRO_LIMIT=2500
PLAN_ENTERPRISE_LIMIT=0

