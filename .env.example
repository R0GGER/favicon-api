PORT=3000
CACHE_DIR=/cache
MEMORY_CACHE_MAX=2000
MEMORY_CACHE_TTL=3600
DISK_CACHE_TTL=86400
UPSTREAM_TIMEOUT=5000
UV_THREADPOOL_SIZE=16

# Number of cluster workers. Leave empty to default to the number of CPU cores.
WORKERS=

# Optional: enables the logo.dev provider (/l/:domain) when set to a valid publishable key.
# Get a key at https://www.logo.dev/
LOGODEV_TOKEN=

# Optional: set the default (first-tried) provider for /:domain requests.
# If omitted, the default fallback order is used (scraper first).
# Valid values: scraper, google, googlev2, duckduckgo, yandex,
#               faviconso, vemetric, favicondev, faviconkit, logodev, selfhst
# Note: logodev requires LOGODEV_TOKEN to be set.
DEFAULT_PROVIDER=

# Optional: base URL of a sidecar besticon (https://github.com/mat/besticon)
# instance. When set, /s/:domain delegates icon discovery to besticon's
# /allicons.json?url=... endpoint and falls back to the built-in HTML scraper
# if besticon is unreachable or returns nothing. Inside the bundled
# docker-compose stack this is normally http://besticon:8080.
BESTICON_URL=

